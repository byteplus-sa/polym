#!/usr/bin/env bash
# super-skill — SA Native AI Skill Package Manager
# https://github.com/Carey8175/sa-super-skill

set -euo pipefail

VERSION="0.1.0"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILLS_SRC="$REPO_DIR/skills"
SKILLS_DST="${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"
LOCK_FILE="$SKILLS_DST/.super-skill.lock"
TEMPLATE_NAME="_template"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

log_info()  { echo -e "${BLUE}▸${NC} $*"; }
log_ok()    { echo -e "${GREEN}✓${NC} $*"; }
log_warn()  { echo -e "${YELLOW}!${NC} $*"; }
log_error() { echo -e "${RED}✗${NC} $*" >&2; }
log_head()  { echo -e "\n${BOLD}$*${NC}"; }

usage() {
  cat <<EOF

${BOLD}super-skill${NC} v${VERSION} — SA Native AI Skill Package Manager

${BOLD}USAGE${NC}
  super-skill install [all]            Install all skills (default)
  super-skill install profile:<name>   Install a named profile bundle
  super-skill install <skill-name>     Install a single skill
  super-skill list                     List all available skills
  super-skill list --installed         List installed skills
  super-skill update                   Pull latest & reinstall
  super-skill doctor                   Check dependencies & env
  super-skill new <name>               Scaffold a new skill

${BOLD}EXAMPLES${NC}
  super-skill install                  # install everything
  super-skill install profile:sa-mvp   # install the SA MVP bundle
  super-skill install meeting-summary  # install one skill
  super-skill doctor                   # verify setup

EOF
}

# ── YAML helpers ──────────────────────────────────────────────────────────────

# Extract skill names from profiles/<name>.yaml includes section
parse_profile_skills() {
  local file="$1"
  grep -E "^  - [a-zA-Z]" "$file" | sed 's/^  - //' | cut -d: -f1 | tr -d '"' | tr -d "'"
}

# Read a top-level scalar from a manifest.yaml
yaml_get() {
  local file="$1" key="$2"
  grep -E "^${key}:" "$file" 2>/dev/null | head -1 | sed "s/^${key}: *//" | tr -d '"'
}

# ── Skill helpers ─────────────────────────────────────────────────────────────

all_skills() {
  for dir in "$SKILLS_SRC"/*/; do
    local name; name=$(basename "$dir")
    [[ "$name" == "$TEMPLATE_NAME" ]] && continue
    echo "$name"
  done
}

skill_exists_src() { [[ -d "$SKILLS_SRC/$1" ]]; }
skill_installed()  { [[ -d "$SKILLS_DST/$1" ]]; }

# ── Lockfile ──────────────────────────────────────────────────────────────────

lock_upsert() {
  local name="$1"
  local version; version=$(yaml_get "$SKILLS_SRC/$name/manifest.yaml" version 2>/dev/null || echo "unknown")
  local ts; ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  mkdir -p "$(dirname "$LOCK_FILE")"
  [[ -f "$LOCK_FILE" ]] || echo '{"skills":[]}' > "$LOCK_FILE"

  python3 - <<PYEOF
import json, sys
lock = json.load(open("$LOCK_FILE"))
lock["skills"] = [s for s in lock["skills"] if s["name"] != "$name"]
lock["skills"].append({
    "name": "$name",
    "version": "$version",
    "installed_at": "$ts",
    "source": "$REPO_DIR"
})
open("$LOCK_FILE", "w").write(json.dumps(lock, indent=2))
PYEOF
}

# ── Core: install one skill ───────────────────────────────────────────────────

install_one() {
  local name="$1"

  if ! skill_exists_src "$name"; then
    log_warn "Skill '$name' not found in source — skipping (not yet implemented?)"
    return 0
  fi

  local stage; stage=$(yaml_get "$SKILLS_SRC/$name/manifest.yaml" stage)
  if [[ "$stage" == "deprecated" ]]; then
    log_warn "Skill '$name' is deprecated — skipping"
    return 0
  fi

  mkdir -p "$SKILLS_DST/$name"
  cp -r "$SKILLS_SRC/$name/." "$SKILLS_DST/$name/"
  lock_upsert "$name"
  log_ok "Installed ${BOLD}$name${NC} (stage: $stage)"
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_install() {
  local target="${1:-all}"
  local -a queue=()

  case "$target" in
    all)
      log_head "Installing all skills → $SKILLS_DST"
      while IFS= read -r s; do queue+=("$s"); done < <(all_skills)
      ;;
    profile:*)
      local pname="${target#profile:}"
      local pfile="$REPO_DIR/profiles/$pname.yaml"
      [[ -f "$pfile" ]] || { log_error "Profile '$pname' not found: $pfile"; exit 1; }
      log_head "Installing profile '${BOLD}$pname${NC}' → $SKILLS_DST"
      while IFS= read -r s; do queue+=("$s"); done < <(parse_profile_skills "$pfile")
      ;;
    *)
      log_head "Installing skill '${BOLD}$target${NC}'"
      queue=("$target")
      ;;
  esac

  mkdir -p "$SKILLS_DST"
  local count=0
  for skill in "${queue[@]}"; do
    if install_one "$skill"; then count=$((count + 1)); fi
  done

  echo ""
  log_ok "Done — ${count} skill(s) installed to $SKILLS_DST"
  log_info "Run ${BOLD}super-skill doctor${NC} to verify dependencies."
}

cmd_list() {
  local mode="${1:-}"

  if [[ "$mode" == "--installed" ]]; then
    log_head "Installed skills"
    if [[ -f "$LOCK_FILE" ]]; then
      python3 - <<PYEOF
import json
lock = json.load(open("$LOCK_FILE"))
skills = lock.get("skills", [])
if not skills:
    print("  (none)")
else:
    for s in sorted(skills, key=lambda x: x["name"]):
        print(f"  {s['name']:<30} v{s['version']:<10} installed {s['installed_at']}")
PYEOF
    else
      echo "  (none — lockfile not found)"
    fi
    return
  fi

  log_head "Available skills"
  local found=0
  while IFS= read -r skill; do
    local stage; stage=$(yaml_get "$SKILLS_SRC/$skill/manifest.yaml" stage 2>/dev/null || echo "unknown")
    local installed=""
    if skill_installed "$skill"; then installed=" ${GREEN}[installed]${NC}"; fi
    printf "  ${BOLD}%-30s${NC} %-14s%b\n" "$skill" "$stage" "$installed"
    found=$((found + 1))
  done < <(all_skills)
  if [[ $found -eq 0 ]]; then echo "  (no skills yet — run 'super-skill new <name>' to add one)"; fi
}

cmd_update() {
  log_head "Pulling latest from $REPO_DIR"
  git -C "$REPO_DIR" pull --ff-only
  echo ""
  cmd_install all
}

cmd_doctor() {
  log_head "Doctor — checking installed skills"
  local issues=0

  while IFS= read -r skill; do
    skill_installed "$skill" || continue
    local manifest="$SKILLS_SRC/$skill/manifest.yaml"
    [[ -f "$manifest" ]] || continue

    # Check required binaries (lines under "binaries:" that start with "    - ")
    local in_binaries=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^[[:space:]]+binaries: ]]; then
        in_binaries=true; continue
      fi
      if $in_binaries; then
        [[ "$line" =~ ^[[:space:]]+-[[:space:]] ]] || { in_binaries=false; continue; }
        local bin; bin=$(echo "$line" | sed 's/.*- //' | cut -d: -f1 | tr -d ' ')
        [[ -z "$bin" ]] && continue
        if ! command -v "$bin" &>/dev/null; then
          log_warn "$skill: missing binary '$bin'"
          (( issues++ )) || true
        fi
      fi
    done < "$manifest"

    # Check required env vars
    local in_env=false
    while IFS= read -r line; do
      if [[ "$line" =~ ^[[:space:]]+env: ]]; then
        in_env=true; continue
      fi
      if $in_env; then
        [[ "$line" =~ ^[[:space:]]+-[[:space:]] ]] || { in_env=false; continue; }
        local var; var=$(echo "$line" | sed 's/.*- //' | tr -d ' ')
        [[ -z "$var" ]] && continue
        if [[ -z "${!var:-}" ]]; then
          log_warn "$skill: env var '\$$var' not set"
          (( issues++ )) || true
        fi
      fi
    done < "$manifest"
  done < <(all_skills)

  echo ""
  if [[ $issues -eq 0 ]]; then
    log_ok "All checks passed."
  else
    log_warn "$issues issue(s) found. Fix the above and re-run doctor."
    exit 1
  fi
}

cmd_new() {
  local name="${1:-}"
  [[ -z "$name" ]] && { log_error "Usage: super-skill new <name>"; exit 1; }

  local dst="$SKILLS_SRC/$name"
  [[ -d "$dst" ]] && { log_error "Skill '$name' already exists at $dst"; exit 1; }

  cp -r "$SKILLS_SRC/$TEMPLATE_NAME" "$dst"
  sed -i.bak "s/TEMPLATE-RENAME-ME/$name/" "$dst/manifest.yaml" && rm -f "$dst/manifest.yaml.bak"
  sed -i.bak "s/TEMPLATE-RENAME-ME/$name/" "$dst/SKILL.md" && rm -f "$dst/SKILL.md.bak"

  log_ok "Scaffolded ${BOLD}$name${NC} at skills/$name/"
  log_info "Next steps:"
  echo "  1. Edit skills/$name/manifest.yaml  (set owners, stage, deps)"
  echo "  2. Edit skills/$name/SKILL.md       (write the skill prompt)"
  echo "  3. Run: super-skill install $name"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

main() {
  case "${1:-}" in
    install)          cmd_install "${2:-all}" ;;
    list)             cmd_list    "${2:-}" ;;
    update)           cmd_update ;;
    doctor)           cmd_doctor ;;
    new)              cmd_new    "${2:-}" ;;
    -v|--version)     echo "super-skill $VERSION" ;;
    -h|--help|"")     usage ;;
    *) log_error "Unknown command: $1"; usage; exit 1 ;;
  esac
}

main "$@"
