# BytePlus Ark access for Seedream image generation.
BYTEPLUS_API_KEY=
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDREAM_MODEL=seedream-4-5-251128

# Optional: upload local/reference images to TOS and pass network URLs to APIs.
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_PREFIX=generated
