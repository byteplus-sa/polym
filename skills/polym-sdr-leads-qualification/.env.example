# LLM provider configuration — set the three required vars then run score_csv.py.
# LiteLLM is auto-installed on first run; no manual pip install needed.

# Required
LLM_API_KEY=
LLM_MODEL=

# Optional — auto-detected from model name if omitted
# Examples: anthropic, openai, gemini, vertex_ai, azure
LLM_PROVIDER=

# Optional — override the provider's default API endpoint
# BytePlus Ark: https://ark.ap-southeast.bytepluses.com/api/v3
# Azure OpenAI: https://<resource>.openai.azure.com
LLM_API_BASE=
