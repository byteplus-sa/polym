# Google backend for Gemini/Imagen image generation.
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ByteDance AIDP backend for Gemini image generation.
AIDP_API_KEY=
AIDP_ENDPOINT=https://aidp.bytedance.net/api/modelhub/online/multimodal/crawl
GEMINI_AIDP_MODEL=gemini-3.1-fi

# Optional: upload local/reference images to TOS and pass network URLs to APIs.
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_PREFIX=generated
