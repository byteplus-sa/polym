# Vertex AI backend for Veo generation.
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VEO_MODEL=veo-3.0-generate-preview

# ByteDance AIDP backend for Veo generation.
AIDP_AK=
AIDP_HOST=aidp.bytedance.net
VEO_AIDP_MODEL=veo-3.0-generate-001

# Optional: upload local/reference media to TOS and pass network URLs to APIs.
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_PREFIX=generated
