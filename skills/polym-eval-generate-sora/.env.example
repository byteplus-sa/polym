# OpenAI backend for Sora generation.
OPENAI_API_KEY=
SORA_MODEL=sora-2

# ByteDance AIDP backend for Sora generation.
AIDP_AK=
AIDP_HOST=aidp.bytedance.net
SORA_AIDP_MODEL=azure-sora2

# Optional: upload local/reference media to TOS and pass network URLs to APIs.
TOS_ENDPOINT=tos-ap-southeast-1.bytepluses.com
TOS_REGION=ap-southeast-1
TOS_BUCKET=
TOS_ACCESS_KEY=
TOS_SECRET_KEY=
TOS_PREFIX=generated
